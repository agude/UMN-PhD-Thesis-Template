@article{DRAGO2021100678,
	title        = {coherent WaveBurst, a pipeline for unmodeled gravitational-wave data analysis},
	author       = {Marco Drago and Sergey Klimenko and Claudia Lazzaro and Edoardo Milotti and Guenakh Mitselmakher and Valentin Necula and Brendan O'Brian and Giovanni Andrea Prodi and Francesco Salemi and Marek Szczepanczyk and Shubhanshu Tiwari and Vaibhav Tiwari and Gayathri V and Gabriele Vedovato and Igor Yakushin},
	year         = 2021,
	journal      = {SoftwareX},
	volume       = 14,
	pages        = 100678,
	doi          = {https://doi.org/10.1016/j.softx.2021.100678},
	issn         = {2352-7110},
	url          = {https://www.sciencedirect.com/science/article/pii/S2352711021000236},
	abstract     = {coherent WaveBurst (cWB) is a highly configurable pipeline designed to detect a broad range of gravitational-wave (GW) transients in the data of the worldwide network of GW detectors. The algorithmic core of cWB is a time--frequency analysis with the Wilson--Daubechies--Meyer wavelets aimed at the identification of GW events without prior knowledge of the signal waveform. cWB has been in active development since 2003 and it has been used to analyze all scientific data collected by the LIGO-Virgo detectors ever since. On September 14, 2015, the cWB low-latency search detected the first gravitational-wave event, GW150914, a merger of two black holes. In 2019, a public open-source version of cWB has been released with GPLv3 license.},
	keywords     = {Gravitational waves, Signal processing, Wavelets},
	bdsk-url-1   = {https://www.sciencedirect.com/science/article/pii/S2352711021000236},
	bdsk-url-2   = {https://doi.org/10.1016/j.softx.2021.100678}
}
